--- subsys/logging/backends/log_backend_fs.c
+++ subsys/logging/backends/log_backend_fs.c
@@ -138,7 +138,43 @@
 
 int write_log_to_file(uint8_t *data, size_t length, void *ctx)
 {
-    /* MASKED - implement this function */
+	int rc;
+	off_t pos;
+
+	if (backend_state == BACKEND_FS_NOT_INITIALIZED) {
+		rc = allocate_new_file(&fs_file);
+		if (rc < 0) {
+			backend_state = BACKEND_FS_CORRUPTED;
+			return rc;
+		}
+		backend_state = BACKEND_FS_OK;
+	}
+
+	if (backend_state != BACKEND_FS_OK) {
+		return -EIO;
+	}
+
+	/* Check if the current write would exceed the file size limit. */
+	pos = fs_tell(&fs_file);
+	if (pos + length > CONFIG_LOG_BACKEND_FS_FILE_SIZE) {
+		fs_close(&fs_file);
+		backend_state = BACKEND_FS_NOT_INITIALIZED;
+
+		rc = allocate_new_file(&fs_file);
+		if (rc < 0) {
+			backend_state = BACKEND_FS_CORRUPTED;
+			return rc;
+		}
+		backend_state = BACKEND_FS_OK;
+	}
+
+	rc = fs_write(&fs_file, data, length);
+	if (rc < 0) {
+		backend_state = BACKEND_FS_CORRUPTED;
+		return rc;
+	}
+
+	return 0;
 }
 
 static int get_log_file_id(struct fs_dirent *ent)




