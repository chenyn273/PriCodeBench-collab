The function is implemented. Here's the logic:

1. **`-ENOTSUP`** — returns if `v_addr` is NULL
2. **Iterates** over all devicetree-defined memory regions
3. **Finds containing region** — if `addr` falls within `[dt_addr, dt_addr + dt_size)`, it checks further
4. **`-ENOSPC`** — if the buffer extends beyond the region boundary (using subtraction `region_end - addr` to avoid overflow)
5. **`-EINVAL`** — if the buffer fits but the region's attributes don't include the requested ones (`(dt_attr & attr) == attr`)
6. **`-ENOBUFS`** — if the address doesn't fall in any known region
7. **`0`** — on success (buffer fully contained and attributes match)


============================================================
=== Diff ===
============================================================
--- subsys/mem_mgmt/mem_attr.c
+++ subsys/mem_mgmt/mem_attr.c
@@ -30,7 +30,35 @@
 
 int mem_attr_check_buf(void *v_addr, size_t size, uint32_t attr)
 {
-    /* MASKED - implement this function */
+	const struct mem_attr_region_t *regions;
+	size_t num_regions;
+	uintptr_t addr;
+
+	if (v_addr == NULL) {
+		return -ENOTSUP;
+	}
+
+	addr = (uintptr_t)v_addr;
+	num_regions = mem_attr_get_regions(&regions);
+
+	for (int i = 0; i < num_regions; ++i) {
+		uintptr_t region_start = regions[i].dt_addr;
+		uintptr_t region_end = region_start + regions[i].dt_size;
+
+		if (addr >= region_start && addr < region_end) {
+			if (size > region_end - addr) {
+				return -ENOSPC;
+			}
+
+			if ((regions[i].dt_attr & attr) == attr) {
+				return 0;
+			}
+
+			return -EINVAL;
+		}
+	}
+
+	return -ENOBUFS;
 }
 
 int mem_attr_get_region_index_by_name(const char *target_name)




