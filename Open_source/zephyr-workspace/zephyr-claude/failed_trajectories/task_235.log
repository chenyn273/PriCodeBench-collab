--- subsys/modem/modem_ubx.c
+++ subsys/modem/modem_ubx.c
@@ -27,7 +27,38 @@
 
 int modem_ubx_run_script(struct modem_ubx *ubx, struct modem_ubx_script *script)
 {
-    /* MASKED - implement this function */
+	int ret;
+
+	/* Wait for exclusive access to run a script */
+	k_sem_take(&ubx->script_running_sem, K_FOREVER);
+
+	/* Set the active script for the process handler to match against */
+	ubx->script = script;
+
+	/* Clear any stale signal from previous script runs */
+	k_sem_reset(&ubx->script_stopped_sem);
+
+	/* Transmit the request frame */
+	ret = modem_pipe_transmit(ubx->pipe, script->request.buf, script->request.len);
+	if (ret < 0) {
+		ubx->script = NULL;
+		k_sem_give(&ubx->script_running_sem);
+		return ret;
+	}
+
+	/* Wait for the response to be matched or timeout */
+	ret = k_sem_take(&ubx->script_stopped_sem, script->timeout);
+	if (ret == -EAGAIN) {
+		ubx->script = NULL;
+		k_sem_give(&ubx->script_running_sem);
+		return -ETIMEDOUT;
+	}
+
+	/* Clean up and return success */
+	ubx->script = NULL;
+	k_sem_give(&ubx->script_running_sem);
+
+	return 0;
 }
 
