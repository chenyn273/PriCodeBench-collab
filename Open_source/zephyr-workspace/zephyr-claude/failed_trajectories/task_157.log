 int log_frontend_stmesp_demux_init(const struct log_frontend_stmesp_demux_config *config)
 {
-    /* MASKED - implement this function */
+	struct mpsc_pbuf_buffer_config mpsc_config;
+
+	if (config == NULL || config->m_ids == NULL || config->m_ids_cnt == 0 ||
+	    config->m_ids_cnt > LOG_FRONTEND_STMESP_DEMUX_MAJOR_MAX ||
+	    config->source_id_buf == NULL || config->source_id_buf_len == 0 ||
+	    (config->source_id_buf_len % config->m_ids_cnt) != 0 ||
+	    (config->source_id_buf_len / config->m_ids_cnt) <= 1) {
+		return -EINVAL;
+	}
+
+	demux.m_ids = config->m_ids;
+	demux.m_ids_cnt = config->m_ids_cnt;
+	demux.source_ids = config->source_id_buf;
+	demux.source_id_len = config->source_id_buf_len / config->m_ids_cnt - 1;
+
+	(void)memset(config->source_id_buf, 0,
+		     config->source_id_buf_len * sizeof(uint32_t));
+
+	k_mem_slab_init(&demux.mslab, slab_buf,
+			sizeof(struct log_frontend_stmesp_demux_active_entry), NUM_OF_ACTIVE);
+
+	mpsc_config.buf = buffer;
+	mpsc_config.size = ARRAY_SIZE(buffer);
+	mpsc_config.notify_drop = notify_drop;
+	mpsc_config.get_wlen = get_wlen;
+	mpsc_config.flags = 0;
+	mpsc_pbuf_init(&demux.pbuf, &mpsc_config);
+
+	sys_slist_init(&demux.active_entries);
+	demux.curr = NULL;
+	demux.curr_m_ch = M_CH_INVALID;
+	demux.dropped = 0;
+
+	(void)memset(demux.coproc_sources, 0, sizeof(demux.coproc_sources));
+
+	return 0;
