============================================================
=== Claude Session ===
============================================================
The implementation: validates that `mgr`, `transitions`, `start`, and `stop` are all non-NULL (returning `-EINVAL` if any is NULL), then initializes all manager fields to their OFF state — empty client and monitor lists, stores the transitions pointer, initializes the spinlock, sets `last_res = 0`, `flags = ONOFF_STATE_OFF` (0), and `refs = 0`.

The `reset` transition is intentionally not checked since it's optional per the API documentation (`onoff_reset()` already handles a NULL reset pointer by returning `-ENOTSUP`).


============================================================
=== Diff ===
============================================================
--- lib/utils/onoff.c
+++ lib/utils/onoff.c
@@ -140,7 +140,21 @@
 int onoff_manager_init(struct onoff_manager *mgr,
 		       const struct onoff_transitions *transitions)
 {
-    /* MASKED - implement this function */
+	if ((mgr == NULL) || (transitions == NULL)
+	    || (transitions->start == NULL)
+	    || (transitions->stop == NULL)) {
+		return -EINVAL;
+	}
+
+	sys_slist_init(&mgr->clients);
+	sys_slist_init(&mgr->monitors);
+	mgr->transitions = transitions;
+	k_spinlock_init(&mgr->lock);
+	mgr->last_res = 0;
+	mgr->flags = ONOFF_STATE_OFF;
+	mgr->refs = 0;
+
+	return 0;
 }
 
 static void notify_monitors(struct onoff_manager *mgr,




