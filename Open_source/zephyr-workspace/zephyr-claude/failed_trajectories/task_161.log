--- subsys/logging/frontends/log_frontend_stmesp_demux.c
+++ subsys/logging/frontends/log_frontend_stmesp_demux.c
@@ -455,7 +455,86 @@
 
 int log_frontend_stmesp_demux_packet_start(uint32_t *data, uint64_t *ts)
 {
-    /* MASKED - implement this function */
+	if (skip) {
+		return 0;
+	}
+
+	if (demux.curr_m_ch == M_CH_INVALID) {
+		return -EINVAL;
+	}
+
+	if (demux.curr != NULL) {
+		/* Previous package was incomplete. Finish it. */
+		log_frontend_stmesp_demux_packet_end();
+		return -EINVAL;
+	}
+
+	/* HW event. */
+	if (demux.curr_m_ch & M_CH_HW_EVENT) {
+		if (data == NULL) {
+			return -EINVAL;
+		}
+
+		log_frontend_stmesp_demux_hw_event(ts, (uint8_t)*data);
+		return 1;
+	}
+
+	uint16_t ch = demux.curr_m_ch & C_ID_MASK;
+	uint16_t m_id_val = demux.curr_m_ch >> M_ID_OFF;
+	uint8_t m = get_major_id(m_id_val);
+
+	/* Trace point (turbo log on trace point channel). */
+	if (ch >= CONFIG_LOG_FRONTEND_STMESP_TP_CHAN_BASE) {
+		if (data == NULL) {
+			store_turbo_log0(m, ch, ts, 0);
+		} else {
+			store_tracepoint(m, ch, ts, data);
+		}
+
+		return 1;
+	}
+
+	/* Regular log message - data must contain the log header. */
+	if (data == NULL) {
+		return -EINVAL;
+	}
+
+	union log_frontend_stmesp_demux_header hdr = {.raw = data[0]};
+	size_t total_wlen = calc_wlen(hdr.log.total_len +
+		offsetof(struct log_frontend_stmesp_demux_log, data));
+	struct log_frontend_stmesp_demux_active_entry *entry;
+
+	/* Override major in the header with the current context index. */
+	hdr.log.major = m;
+
+	if (k_mem_slab_alloc(&demux.mslab, (void **)&entry, K_NO_WAIT) != 0) {
+		return -ENOMEM;
+	}
+
+	union log_frontend_stmesp_demux_packet pkt = {
+		.generic = mpsc_pbuf_alloc(&demux.pbuf, total_wlen, K_NO_WAIT)
+	};
+
+	if (pkt.generic == NULL) {
+		k_mem_slab_free(&demux.mslab, entry);
+		return -ENOMEM;
+	}
+
+	pkt.log->type = LOG_FRONTEND_STMESP_DEMUX_TYPE_LOG;
+	pkt.log->content_invalid = 0;
+	pkt.log->timestamp = ts ? *ts : 0;
+	pkt.log->hdr = hdr.log;
+	pkt.log->padding = 0;
+
+	entry->m_ch = demux.curr_m_ch;
+	entry->ts = ts ? *ts : 0;
+	entry->packet = pkt.log;
+	entry->off = 0;
+
+	sys_slist_append(&demux.active_entries, &entry->node);
+	demux.curr = entry;
+
+	return 0;
 }
 
