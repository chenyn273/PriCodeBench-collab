============================================================
=== Claude Session ===
============================================================
Implemented `osMailFree`. It follows the exact same patterns as the other functions in the file:

- Casts `queue_id` to `osMailQDef_t *` and validates both parameters (same pattern as `osMailPut`)
- Frees the block via `k_mem_slab_free`, the inverse of `k_mem_slab_alloc` used in `osMailAlloc` and `osMailCAlloc`
- Returns `osOK` on success, `osErrorParameter` for NULL queue, `osErrorValue` for NULL mail pointer


============================================================
=== Diff ===
============================================================
--- subsys/portability/cmsis_rtos_v1/cmsis_mailq.c
+++ subsys/portability/cmsis_rtos_v1/cmsis_mailq.c
@@ -168,5 +168,16 @@
  */
 osStatus osMailFree(osMailQId queue_id, void *mail)
 {
-    /* MASKED - implement this function */
+	osMailQDef_t *queue_def = (osMailQDef_t *)queue_id;
+
+	if (queue_def == NULL) {
+		return osErrorParameter;
+	}
+
+	if (mail == NULL) {
+		return osErrorValue;
+	}
+
+	k_mem_slab_free((struct k_mem_slab *)(queue_def->pool), &mail);
+	return osOK;
 }




