--- lib/os/spsc_pbuf.c
+++ lib/os/spsc_pbuf.c
@@ -136,7 +136,120 @@
 
 int spsc_pbuf_alloc(struct spsc_pbuf *pb, uint16_t len, char **buf)
 {
-    /* MASKED - implement this function */
+	const uint32_t pblen = pb->common.len;
+	const uint32_t flags = pb->common.flags;
+	uint32_t *rd_idx_loc = get_rd_idx_loc(pb, flags);
+	uint32_t *wr_idx_loc = get_wr_idx_loc(pb, flags);
+	uint8_t *data_loc = get_data_loc(pb, flags);
+
+	if (len == 0) {
+		return -EINVAL;
+	}
+
+	cache_inv(rd_idx_loc, sizeof(*rd_idx_loc), flags);
+	barrier_sync_synchronize();
+
+	uint32_t wr_idx = *wr_idx_loc;
+	uint32_t rd_idx = *rd_idx_loc;
+
+	if (len == SPSC_PBUF_MAX_LEN) {
+		/* Return largest contiguous allocation without wrap padding. */
+		uint32_t space;
+
+		if (wr_idx < rd_idx) {
+			space = (rd_idx > wr_idx + FREE_SPACE_DISTANCE)
+				? (rd_idx - wr_idx - FREE_SPACE_DISTANCE) : 0;
+		} else {
+			space = pblen - wr_idx;
+		}
+
+		if (space < LEN_SZ) {
+			return 0;
+		}
+
+		uint32_t avail = ROUND_DOWN(space, sizeof(uint32_t));
+		uint32_t payload = avail - LEN_SZ;
+
+		if (payload == 0) {
+			return 0;
+		}
+
+		*buf = (char *)&data_loc[wr_idx + LEN_SZ];
+		return payload;
+	}
+
+	uint32_t need = ROUND_UP((uint32_t)len + LEN_SZ, sizeof(uint32_t));
+	uint32_t space;
+
+	/* Contiguous free space from wr_idx (before any wrapping). */
+	if (wr_idx < rd_idx) {
+		/* Writer behind reader: free space is the gap between them. */
+		space = (rd_idx > wr_idx + FREE_SPACE_DISTANCE)
+			? (rd_idx - wr_idx - FREE_SPACE_DISTANCE) : 0;
+	} else {
+		space = pblen - wr_idx;
+	}
+
+	if (need <= space) {
+		/* Enough contiguous space at current write position. */
+		*buf = (char *)&data_loc[wr_idx + LEN_SZ];
+		return len;
+	}
+
+	/* Not enough contiguous space; try wrapping to the beginning. */
+	if (wr_idx != 0 && rd_idx > FREE_SPACE_DISTANCE) {
+		uint32_t space_at_start = rd_idx - FREE_SPACE_DISTANCE;
+
+		if (need <= space_at_start) {
+			/* Write padding marker at current position and wrap. */
+			data_loc[wr_idx] = PADDING_MARK;
+			barrier_sync_synchronize();
+			cache_wb(&data_loc[wr_idx], sizeof(uint8_t), flags);
+
+			*wr_idx_loc = 0;
+			barrier_sync_synchronize();
+			cache_wb(wr_idx_loc, sizeof(*wr_idx_loc), flags);
+
+			*buf = (char *)&data_loc[LEN_SZ];
+			return len;
+		}
+	}
+
+	/* Best-fit: largest possible at current position (no wrap padding). */
+	if (space >= LEN_SZ) {
+		uint32_t avail = ROUND_DOWN(space, sizeof(uint32_t));
+		uint32_t payload = avail - LEN_SZ;
+
+		if (payload > 0) {
+			*buf = (char *)&data_loc[wr_idx + LEN_SZ];
+			return payload;
+		}
+	}
+
+	/* Best-fit: largest possible with wrapping. */
+	if (wr_idx != 0 && rd_idx > FREE_SPACE_DISTANCE) {
+		uint32_t space_at_start = rd_idx - FREE_SPACE_DISTANCE;
+
+		if (space_at_start >= LEN_SZ) {
+			uint32_t avail = ROUND_DOWN(space_at_start, sizeof(uint32_t));
+			uint32_t payload = avail - LEN_SZ;
+
+			if (payload > 0) {
+				data_loc[wr_idx] = PADDING_MARK;
+				barrier_sync_synchronize();
+				cache_wb(&data_loc[wr_idx], sizeof(uint8_t), flags);
+
+				*wr_idx_loc = 0;
+				barrier_sync_synchronize();
+				cache_wb(wr_idx_loc, sizeof(*wr_idx_loc), flags);
+
+				*buf = (char *)&data_loc[LEN_SZ];
+				return payload;
+			}
+		}
+	}
+
+	return -ENOMEM;
 }
 
 void spsc_pbuf_commit(struct spsc_pbuf *pb, uint16_t len)




