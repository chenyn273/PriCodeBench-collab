The implementation is in place. Here's a summary of what `pm_device_runtime_enable` does:

1. **`-ENOTSUP`** — if `dev->pm` is NULL (device doesn't support PM)
2. **Early return 0** — if runtime PM is already enabled
3. **ISR-safe path** — delegates to `runtime_enable_sync()` (spinlock, suspends if active)
4. **Normal path** — acquires the semaphore lock (skipped in pre-kernel mode), suspends the device if it's in `PM_DEVICE_STATE_ACTIVE`, then sets `PM_DEVICE_FLAG_RUNTIME_ENABLED` and resets usage to 0
5. **Tracing** — `SYS_PORT_TRACING_FUNC_ENTER`/`EXIT` calls matching the pattern used by all other functions in this file


============================================================
=== Diff ===
============================================================
--- subsys/pm/device_runtime.c
+++ subsys/pm/device_runtime.c
@@ -446,7 +446,53 @@
 
 int pm_device_runtime_enable(const struct device *dev)
 {
-    /* MASKED - implement this function */
+	int ret = 0;
+	struct pm_device *pm = dev->pm;
+
+	SYS_PORT_TRACING_FUNC_ENTER(pm, device_runtime_enable, dev);
+
+	if (pm == NULL) {
+		ret = -ENOTSUP;
+		goto end;
+	}
+
+	if (atomic_test_bit(&pm->base.flags, PM_DEVICE_FLAG_RUNTIME_ENABLED)) {
+		goto end;
+	}
+
+	if (atomic_test_bit(&dev->pm_base->flags, PM_DEVICE_FLAG_ISR_SAFE)) {
+		ret = runtime_enable_sync(dev);
+		goto end;
+	}
+
+	if (!k_is_pre_kernel()) {
+		ret = k_sem_take(&pm->lock, K_FOREVER);
+		if (ret < 0) {
+			goto end;
+		}
+	}
+
+	if (pm->base.state == PM_DEVICE_STATE_ACTIVE) {
+		ret = pm->base.action_cb(dev, PM_DEVICE_ACTION_SUSPEND);
+		if (ret < 0) {
+			goto unlock;
+		}
+
+		pm->base.state = PM_DEVICE_STATE_SUSPENDED;
+	}
+
+	atomic_set_bit(&pm->base.flags, PM_DEVICE_FLAG_RUNTIME_ENABLED);
+	pm->base.usage = 0U;
+
+unlock:
+	if (!k_is_pre_kernel()) {
+		k_sem_give(&pm->lock);
+	}
+
+end:
+	SYS_PORT_TRACING_FUNC_EXIT(pm, device_runtime_enable, dev, ret);
+
+	return ret;
 }
 
 static int runtime_disable_sync(const struct device *dev)




