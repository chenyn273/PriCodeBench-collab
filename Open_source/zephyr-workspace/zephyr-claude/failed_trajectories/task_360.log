--- subsys/portability/cmsis_rtos_v2/timer.c
+++ subsys/portability/cmsis_rtos_v2/timer.c
@@ -37,7 +37,41 @@
 osTimerId_t osTimerNew(osTimerFunc_t func, osTimerType_t type, void *argument,
 		       const osTimerAttr_t *attr)
 {
-    /* MASKED - implement this function */
+	struct cmsis_rtos_timer_cb *timer;
+
+	if (func == NULL) {
+		return NULL;
+	}
+
+	if (attr == NULL) {
+		attr = &init_timer_attrs;
+	}
+
+	if (attr->cb_mem != NULL) {
+		if (attr->cb_size < sizeof(struct cmsis_rtos_timer_cb)) {
+			return NULL;
+		}
+
+		timer = (struct cmsis_rtos_timer_cb *)attr->cb_mem;
+		timer->is_cb_dynamic_allocation = false;
+	} else {
+		if (k_mem_slab_alloc(&cmsis_rtos_timer_cb_slab, (void **)&timer,
+				    K_NO_WAIT) != 0) {
+			return NULL;
+		}
+
+		timer->is_cb_dynamic_allocation = true;
+	}
+
+	timer->type = type;
+	timer->status = NOT_ACTIVE;
+	timer->name = attr->name;
+	timer->callback_function = func;
+	timer->arg = argument;
+
+	k_timer_init(&timer->z_timer, zephyr_timer_wrapper);
+
+	return (osTimerId_t)timer;
