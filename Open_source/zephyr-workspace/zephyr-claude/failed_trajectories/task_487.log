--- lib/mem_blocks/mem_blocks.c
+++ lib/mem_blocks/mem_blocks.c
@@ -347,7 +347,33 @@
 			       void **out_blocks,
 			       size_t *blk_size)
 {
-    /* MASKED - implement this function */
+	int ret = 0;
+	sys_mem_blocks_t *chosen;
+
+	__ASSERT_NO_MSG(group != NULL);
+	__ASSERT_NO_MSG(out_blocks != NULL);
+
+	if (count == 0) {
+		goto out;
+	}
+
+	chosen = group->choice_fn(group, cfg);
+	if (chosen == NULL) {
+		ret = -EINVAL;
+		goto out;
+	}
+
+	ret = sys_mem_blocks_alloc(chosen, count, out_blocks);
+	if (ret != 0) {
+		goto out;
+	}
+
+	if (blk_size != NULL) {
+		*blk_size = BIT(chosen->info.blk_sz_shift);
+	}
+
+out:
+	return ret;
 }
 
 int sys_multi_mem_blocks_free(sys_multi_mem_blocks_t *group,




